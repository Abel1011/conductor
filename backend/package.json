{
  "name": "conductor-backend",
  "version": "0.1.0",
  "description": "Real backend for the Conductor hackathon MVP",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "seed": "node seed.js",
    "seed:source": "node ..\\infra\\source-db\\seed.js",
    "spike:source": "node ..\\infra\\source-db\\spike.js",
    "check": "powershell -NoProfile -Command \"Get-ChildItem -Path src -Recurse -Filter *.js | ForEach-Object { node --check $_.FullName }\""
  },
  "keywords": [
    "conductor",
    "express",
    "sse",
    "hackathon"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google-cloud/bigquery": "^7.9.4",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.16.3"
  }
}
